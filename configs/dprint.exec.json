{
	"exec": {
		"commands": [
			{
				"command": "tombi format - --stdin-filename {{file_path}}",
				"exts": [
					"toml"
				]
			},
			{
				"command": "shfmt -i 0 -ln bash -bn -ci -filename {{file_path}}",
				"exts": [
					"sh",
					"bash"
				]
			},
			{
				"command": "just --dump --justfile {{file_path}}",
				"fileNames": [
					"justfile"
				]
			},
			{
				"command": "rustfmt --edition 2024",
				"exts": ["rs"]
			},
			{
				"command": "sort-package-json --stdin",
				"fileNames": [
					"package.json"
				]
			},
			{
				"command": "svgo --indent -1 --multipass --pretty -q -i - -o -",
				"exts": [
					"svg"
				]
			}
		]
	},
	"plugins": [
		"https://plugins.dprint.dev/exec-0.6.2.json@df98f54ffd3092b8a841aedd6d098a2651f16d0a796a40535774f1a8b4b9d463"
	]
}
