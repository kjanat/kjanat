{
	"$schema": "https://dprint.dev/schemas/v0.json",
	"extends": "https://github.com/kjanat/kjanat/raw/9c3457f3/configs/dprint.remote.json",
	"useTabs": true,
	"indentWidth": 2,
	"newLineKind": "lf",
	"biome": { "indentStyle": "tab", "lineWidth": "120", "quoteStyle": "single" },
	"markup": {
		"useTabs": true,
		"html.void.selfClosing": false,
		"formatComments": true,
		"scriptIndent": true,
		"scriptFormatter": "biome",
		"styleIndent": true,
		"doctypeKeywordCase": "upper",
		"strictSvelteAttr": false,
		"svelteAttrShorthand": true,
		"svelteDirectiveShorthand": true,
		"ignoreCommentDirective": "dprint-ignore",
		"ignoreFileCommentDirective": "dprint-ignore-file",
		"associations": ["!**/*.svg"]
	},
	"typescript": { "associations": ["!**/*.*{ts,js}"] },
	"excludes": ["**/.venv", "**/{*-,bun}lock(.*)?", "**/node_modules", "**/worker-configuration.d.ts"],
	"plugins": [
		"https://plugins.dprint.dev/biome-0.13.0.wasm",
		"https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.3.wasm",
		"https://plugins.dprint.dev/typescript-0.96.1.wasm"
	]
}
