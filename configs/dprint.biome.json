{
	"extends": "https://raw.githubusercontent.com/kjanat/kjanat/refs/heads/master/configs/dprint.remote.json",
	"useTabs": true,
	"indentWidth": 2,
	"newLineKind": "lf",
	"biome": {
		"quoteStyle": "single",
		"indentStyle": "tab",
		"lineWidth": "120"
	},
	"typescript": {
		"associations": ["!**/*.*{ts,js}"]
	},
	"markup": { "scriptFormatter": "biome" },
	"excludes": ["**/node_modules", "**/*-lock.json", "**/.venv", "**/bun.lock*", "**/worker-configuration.d.ts"],
	"plugins": [
		"https://plugins.dprint.dev/biome-0.12.2.wasm",
		"https://plugins.dprint.dev/typescript-0.95.15.wasm"
	]
}
