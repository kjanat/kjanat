{
	"extends": "https://raw.githubusercontent.com/kjanat/kjanat/refs/heads/master/configs/dprint.remote.json",
	"useTabs": true,
	"indentWidth": 2,
	"newLineKind": "lf",
	"biome": {
		"indentStyle": "tab",
		"lineWidth": "120",
		"quoteStyle": "single"
	},
	"markup": {
		"useTabs": true,
		"html.void.selfClosing": false,
		"formatComments": true,
		"scriptIndent": true,
		"scriptFormatter": "biome",
		"styleIndent": true,
		"doctypeKeywordCase": "upper",
		"strictSvelteAttr": false,
		"svelteAttrShorthand": true,
		"svelteDirectiveShorthand": true,
		"ignoreCommentDirective": "dprint-ignore",
		"ignoreFileCommentDirective": "dprint-ignore-file",
		"associations": ["!**/*.svg"]
	},
	"typescript": {
		"associations": ["!**/*.*{ts,js}"]
	},
	"plugins": [
		"https://plugins.dprint.dev/biome-0.12.6.wasm",
		"https://plugins.dprint.dev/typescript-0.95.15.wasm",
		"https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.0.wasm"
	],
	"excludes": [
		"**/.venv",
		"**/{*-,bun}lock(.*)?",
		"**/node_modules",
		"**/worker-configuration.d.ts"
	]
}
